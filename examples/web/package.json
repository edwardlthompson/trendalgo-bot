{
  "name": "trendalgo-web",
  "private": true,
  "license": "MIT",
  "version": "0.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "gen:data": "cd ../.. && uv run python scripts/gen-web-data-ts.py && uv run python scripts/gen-ta-glossary-json.py && uv run python scripts/gen-ta-library-json.py",
    "lint": "tsc --noEmit",
    "lighthouse": "lhci autorun"
  },
  "dependencies": {
    "lightweight-charts": "~4.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "jsdom": "^29.1.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.8"
  },
  "overrides": {
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "js-yaml": ">=4.2.0",
    "undici": ">=7.28.0 <8.0.0"
  }
}
