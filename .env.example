# Environment variables (copy to .env — never commit .env)

# --- TrendAlgo core ---
TRENDALGO_MODE=dry-run
# Local dev data dir (see docs/LOCAL_DEV.md)
# TRENDALGO_DATA_DIR=./data/dev
# TRENDALGO_API_PORT=8000
# Comma-separated CORS origins for API (default * for local dev; restrict in production)
# TRENDALGO_CORS_ORIGINS=https://your-vps.example,https://pages.github.io
LOG_LEVEL=info
DATABASE_URL=sqlite:///./data/trendalgo.db
TZ=America/Puerto_Rico

# --- Native engine (S15+) — no Freqtrade RPC ---
# GO_LIVE_APPROVED=0
# WORLDWIDE_TRADING_ACK=0  # required for live on us_restricted venues (binance/bybit/okx)

# --- Kraken (read-only for portfolio; trade keys with NO Withdraw permission) ---
# KRAKEN_API_KEY=
# KRAKEN_API_SECRET=

# --- Binance.US (S13 — read-only portfolio; NOT global binance.com) ---
# BINANCEUS_API_KEY=
# BINANCEUS_API_SECRET=

# --- Tier B US portfolio (S14 — read-only) ---
# COINBASEADVANCED_API_KEY=
# COINBASEADVANCED_API_SECRET=
# GEMINI_API_KEY=
# GEMINI_API_SECRET=
# BITSTAMP_API_KEY=
# BITSTAMP_API_SECRET=
# CRYPTOCOM_API_KEY=
# CRYPTOCOM_API_SECRET=

# --- Worldwide portfolio (S14 — read-only; us_restricted for US operators) ---
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BYBIT_API_KEY=
# BYBIT_API_SECRET=
# OKX_API_KEY=
# OKX_API_SECRET=

# Stagger between exchange sync jobs (seconds; 0 = no delay, dev/tests)
# TRENDALGO_SYNC_STAGGER_SEC=15

# --- DEX / on-chain wallet read (S21 — public RPC, dry-run default) ---
# ETH_RPC_URL=
# BASE_RPC_URL=
# ARB_RPC_URL=
# SOLANA_RPC_URL=
# ONCHAIN_SYNC_ENABLED=0
# DEX_TRADING_ACK=0  # required for /platform/dex/dry-run when bot is not in dry-run mode (S23)
# DEX_LIVE_TRADING_ACK=0  # H-036: required for /platform/dex/live on VPS (never commit)
# DEX_SIGNER_KEY=  # VPS only — live swap signing (CM-9); never in API/logs/git
# DEX_MAX_SLIPPAGE_BPS=100  # max slippage for live swaps (S24)
# BASE_RPC_URL_FALLBACK=  # optional RPC failover (S24)
# JUPITER_QUOTES_ENABLED=0  # optional live Jupiter quote preview on Solana
# ZERO_EX_QUOTES_ENABLED=0  # set 1 with API key for live quotes
# TRENDALGO_VENUE_SYNC_STAGGER_SEC=0  # multi-chain sync delay (dev/tests)

# --- Telegram (H-008) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# NOTIFICATION_DAILY_HOUR=8

# --- AI (optional — Ollama local dev) ---
# OLLAMA_HOST=http://127.0.0.1:11434
# AI_API_ENABLED=false

# --- Performance license settlement (S10 — user-initiated BTC payment) ---
# Operator public BTC address (required for live settlement)
# TRENDALGO_SETTLEMENT_ADDRESS=bc1q...
# EVM address for USDC/USDT on Base (same wallet for both stablecoins)
# TRENDALGO_SETTLEMENT_EVM_ADDRESS=0x...
# TRENDALGO_SETTLEMENT_ASSET=BTC
# Block explorer API base (default: https://blockstream.info/api)
# TRENDALGO_ESPLORA_URL=https://blockstream.info/api
# Base JSON-RPC for stablecoin transfer verification (default: https://mainnet.base.org)
# TRENDALGO_BASE_RPC_URL=https://mainnet.base.org
# Optional token contract overrides on Base
# TRENDALGO_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# TRENDALGO_USDT_CONTRACT=0xfde4C96c8593536e31F229EA8f37b2ADa2699bb2
# Fixed BTC/USD rate for tests or offline dev (optional; otherwise CoinGecko)
# TRENDALGO_BTC_USD_RATE=95000
# Dev/test: auto-confirm payments without on-chain lookup
# TRENDALGO_PAYMENT_SIMULATE=0

# --- Production (VPS only — ADR-0002) ---
# DEPLOY_TARGET=external_vps
# PUBLIC_URL=https://your-vps.example.com

# Template update checker (optional)
# TEMPLATE_UPSTREAM=edwardlthompson/agent-project-bootstrap
